// Court Vision Prisma schema: Player / PlayerSeasonStats / PlayerGameLog.
// See PRD §8 (Data and Sync Strategy).
//
// Prisma 7: the connection URL lives in prisma.config.ts (not here), and the
// client is generated to ../generated/prisma via the `prisma-client` generator.

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Player {
  id           Int                 @id
  firstName    String
  lastName     String
  fullName     String
  teamId       Int?
  teamAbbr     String?
  position     String?
  jerseyNumber String?
  nbaPersonId  Int?
  heightInches Int?
  weightLbs    Int?
  birthDate    DateTime?
  college      String?
  country      String?
  draftYear    Int?
  draftRound   Int?
  draftNumber  Int?
  seasonStats  PlayerSeasonStats[]
  gameLogs     PlayerGameLog[]
  advancedGameLogs PlayerAdvancedGameLog[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

model Profile {
  id          String   @id @db.Uuid
  email       String
  username    String   @unique
  tier        String   @default("free")
  displayName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PlayerSeasonStats {
  id          String   @id @default(cuid())
  player      Player   @relation(fields: [playerId], references: [id])
  playerId    Int
  season      String
  seasonType  String
  gamesPlayed Int
  minutes     Float
  fgm         Int
  fga         Int
  fg3m        Int
  fg3a        Int
  ftm         Int
  fta         Int
  oreb        Int
  dreb        Int
  reb         Int
  ast         Int
  stl         Int
  blk         Int
  tov         Int
  pts         Int
  updatedAt   DateTime @updatedAt

  @@unique([playerId, season, seasonType])
}

model PlayerGameLog {
  id           String   @id @default(cuid())
  player       Player   @relation(fields: [playerId], references: [id])
  playerId     Int
  gameId       String
  gameDate     DateTime
  season       String
  seasonType   String
  teamId       Int
  teamAbbr     String
  matchup       String
  opponentAbbr  String?
  homeAway      String
  winLoss       String?
  teamScore     Int?
  opponentScore Int?
  minutes       Float
  fgm          Int
  fga          Int
  fg3m         Int
  fg3a         Int
  ftm          Int
  fta          Int
  oreb         Int
  dreb         Int
  reb          Int
  ast          Int
  stl          Int
  blk          Int
  tov          Int
  pts          Int
  plusMinus    Int?

  @@unique([playerId, gameId])
  @@index([gameDate])
  @@index([playerId, gameDate])
}

// Per-game advanced metrics from Balldontlie's /v1/stats/advanced. Kept in
// its own table (same [playerId, gameId] identity as PlayerGameLog) so the
// advanced sync can replace seasons independently of box-score logs. Metrics
// are nullable: BDL returns null for players who logged no minutes.
model PlayerAdvancedGameLog {
  id                           String   @id @default(cuid())
  player                       Player   @relation(fields: [playerId], references: [id])
  playerId                     Int
  gameId                       String
  gameDate                     DateTime
  season                       String
  seasonType                   String
  teamId                       Int
  teamAbbr                     String
  pie                          Float?
  pace                         Float?
  assistPercentage             Float?
  assistRatio                  Float?
  assistToTurnover             Float?
  defensiveRating              Float?
  defensiveReboundPercentage   Float?
  effectiveFieldGoalPercentage Float?
  netRating                    Float?
  offensiveRating              Float?
  offensiveReboundPercentage   Float?
  reboundPercentage            Float?
  trueShootingPercentage       Float?
  turnoverRatio                Float?
  usagePercentage              Float?

  @@unique([playerId, gameId])
  @@index([playerId, gameDate])
}

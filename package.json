{
  "name": "court-vision",
  "version": "0.1.2",
  "private": true,
  "scripts": {
    "dev": "next dev --port 46644",
    "build": "next build",
    "start": "next start",
    "lint": "run-s lint:ts lint:scss",
    "lint:ts": "oxlint --type-aware --deny-warnings",
    "lint:fix": "oxlint --type-aware --fix",
    "lint:scss": "gale \"src/**/*.scss\"",
    "typecheck": "next typegen && tsgo --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "prepare": "husky",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "postinstall": "prisma generate",
    "sync:nba": "bun run src/lib/nba/sync.ts",
    "sync:bdl": "bun run src/lib/balldontlie/sync.ts",
    "sync:players": "bun run src/lib/balldontlie/sync-players.ts",
    "seed:demo": "bun run src/lib/demo/seed.ts",
    "map:headshots": "bun run src/lib/headshots/map.ts",
    "system-check": "run-s format:check lint typecheck test build"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@supabase/ssr": "0.12.0",
    "@supabase/supabase-js": "2.110.2",
    "lucide-react": "1.24.0",
    "next": "16.2.9",
    "nuqs": "2.9.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "3.9.2",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@lyricalstring/gale": "0.1.5",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "20.19.43",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "@vitejs/plugin-react": "6.0.2",
    "dotenv": "17.4.2",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "npm-run-all2": "9.0.1",
    "oxfmt": "0.60.0",
    "oxlint": "1.75.0",
    "oxlint-tsgolint": "7.0.2001",
    "prisma": "7.8.0",
    "sass": "1.101.0",
    "typescript": "5.9.3",
    "vitest": "4.1.8"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "@lyricalstring/gale",
    "@parcel/watcher",
    "@prisma/engines",
    "prisma",
    "sharp",
    "unrs-resolver"
  ]
}

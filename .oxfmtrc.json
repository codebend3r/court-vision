{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "printWidth": 100,
  "tabWidth": 2,
  "sortPackageJson": false,
  "ignorePatterns": [
    ".next/",
    "out/",
    "build/",
    "coverage/",
    "generated/",
    "bun.lock",
    "next-env.d.ts",
    "prisma/migrations/"
  ]
}

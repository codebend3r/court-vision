# PostgreSQL connection string. No live database is wired up yet — fill this in
# when the data-layer work begins, then copy this file to `.env`.
# See prisma/schema.prisma.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/court_vision?schema=public"

# Balldontlie API key — required by `bun run sync:bdl`.
# Get one at https://www.balldontlie.io/. Per-game stats need the ALL-STAR tier;
# the free tier has no /v1/stats access.
BALLDONTLIE_API_KEY="YOUR_BALLDONTLIE_API_KEY"

# Supabase auth keys (public, exposed to the browser, so safe to ship). Both must
# be set to enable login/signup; when either is blank the auth middleware no-ops
# and pages render signed-out instead of throwing. Find them under the project's
# API settings (https://supabase.com/dashboard/project/_/settings/api).
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="YOUR_SUPABASE_PUBLISHABLE_KEY"
